---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="four-oh-four-container">
    <h1 class="text-headline">404: Page Not Found</h1>
    <p>Oops!<br> Really sorry about that. That page is either gone, or possibly never existed. Try looking through the navigation at the top of the page, or <a href="mailto:matt.soria@hey.com?subject=Hey%20Matt!" class="basic-link">email me</a> if you think I should make it. :peace:</p>
  </div>
</Layout>

<style scoped>
  .four-oh-four-container {
    display: flex;
    text-align: center;
    align-items: center;
    gap: var(--spacing-m);
    flex-direction: column;
    justify-content: center;
    padding-block: var(--spacing-4xl);
    padding-inline: var(--site-gutter);
  }

  h1 {
    text-wrap: balance;

    @media screen and (prefers-reduced-motion: no-preference) {
      filter: url('#distortionFilter');
    }
  }

  p {
    max-width: 50ch;
    text-wrap: pretty;
  }
</style>