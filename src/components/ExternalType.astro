---
const { type } = Astro.props;
let icon = '';

if (type === 'book') {
  icon = '📖';
} else if (type === 'article') {
  icon = '📰';
} else if (type === 'podcast') {
  icon = '🎙';
} else if (type === 'music') {
  icon = '🎵';
} else if (type === 'movie') {
  icon = '🎥';
} else if (type === 'tv-show') {
  icon = '📺';
} else if (type === 'video') {
  icon = '📼';
} else if (type === 'game') {
  icon = '🎮';
} else if (type === 'website') {
  icon = '🌐';
} else if (type === 'app') {
  icon = '📱';
}
---

<a href={`/links/type/${type}`}>
  <div set:html={icon} aria-hidden="true"></div>
  <div set:html={type} class="visually-hidden"></div>
</a>

<style scoped>
  a {
    text-decoration: none;
    
    &:hover,
    &:focus-visible {
      div {
        transform: scale(1.1);
      }
    }
    
    div {
      font-size: 1em;
      text-box-trim: trim-both;
      margin-block-end: -0.2em;
      transition: transform 0.2s ease-out;
    }
  } 
</style>