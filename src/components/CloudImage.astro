---
import { CldImage } from 'astro-cloudinary';

const { url, alt, width, height, zoomable, focalPoint, containerClasses, imgClasses } = Astro.props;
const additionalContainerClasses = containerClasses ? containerClasses : "";
const additionalImgClasses = imgClasses ? imgClasses : "";
let objectPosition = "center";
if (focalPoint) {
 objectPosition = `${focalPoint[0] * 100}% ${focalPoint[1] * 100}%`;
}

let divClass, imgClass, nscClass, dataSzes;

divClass = `image-wrapper ${additionalContainerClasses}`;
dataSzes = `(min-width: 768px) 100vw, 50vw`;
nscClass = `nsc-image`;
imgClass = `image animate-fade lazyload ${additionalImgClasses}`;
---

<style define:vars={{ objectPosition }}>
  .image-wrapper {
    width: 100%;
    height: 100%;
    overflow: hidden;
    object-fit: cover;
  }

  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-fade {
    animation: fadeIn 750ms ease-in-out;
  }

  .nsc-image,
  .image {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
  }
</style>

<div class={divClass} data-pagefind-ignore>
  <CldImage
    src={url}
    width={width}
    height={height}
    sizes={dataSzes}
    alt={alt ?? ''}
    data-zoomable={zoomable}
    data-pagefind-ignore
    class={imgClass}
    style={'object-position: ' + objectPosition}
  />
</div>